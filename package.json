{
    "name": "relay",
    "displayName": "Relay",
    "description": "",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "relay.helloWorld",
                "title": "Hello World"
            }
        ],
        "viewsContainers": {
            "panel": [
                {
                    "id": "relayPanelContainer",
                    "title": "Ray",
                    "icon": "media/ray-icon.svg"
                }
            ]
        },
        "views": {
            "relayPanelContainer": [
                {
                    "type": "webview",
                    "id": "relayPanel.view",
                    "name": "Relay"
                }
            ]
        },
        "configuration": {
            "title": "Relay Panel",
            "properties": {
                "relayPanel.port": {
                    "type": "number",
                    "default": 23517
                },
                "relayPanel.host": {
                    "type": "string",
                    "default": "127.0.0.1",
                    "description": "Bind address. Use 0.0.0.0 to accept from Docker/Lando containers on Linux."
                },
                "relayPanel.maxItems": {
                    "type": "number",
                    "default": 500
                },
                "relayPanel.resolveOriginsFromWorkspace": {
                    "type": "boolean",
                    "default": true,
                    "description": "When an origin path isn't found on disk as-is, locate the file by its tail under the window's workspace folders (zero-config click-to-jump for container paths). Disable to require explicit relayPanel.pathMappings."
                },
                "relayPanel.pathMappings": {
                    "type": "array",
                    "default": [],
                    "description": "Explicit override for click-to-jump (highest precedence). Each entry rewrites a remote path prefix to a local one, e.g. { \"remote\": \"/app\", \"local\": \"/Users/you/project\" }. Use to disambiguate when the same relative path exists in multiple open folders.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "remote": { "type": "string" },
                            "local": { "type": "string" }
                        },
                        "required": ["remote", "local"]
                    }
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.120.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "typescript-eslint": "^8.56.1",
        "eslint": "^9.39.3",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2"
    }
}
