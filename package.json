{
    "name": "relay",
    "displayName": "Relay",
    "description": "",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "relay.clear",
                "title": "Clear Output",
                "category": "Relay",
                "icon": "$(clear-all)"
            },
            {
                "command": "relay.toggleServer",
                "title": "Toggle Server",
                "category": "Relay"
            },
            {
                "command": "relay.selectColorStyle",
                "title": "Color Style…",
                "category": "Relay",
                "icon": "$(symbol-color)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "relay.selectColorStyle",
                    "when": "view == relayPanel.view",
                    "group": "navigation@1"
                },
                {
                    "command": "relay.clear",
                    "when": "view == relayPanel.view",
                    "group": "navigation@2"
                }
            ]
        },
        "viewsContainers": {
            "panel": [
                {
                    "id": "relayPanelContainer",
                    "title": "Relay",
                    "icon": "media/ray-icon.svg"
                }
            ]
        },
        "views": {
            "relayPanelContainer": [
                {
                    "type": "webview",
                    "id": "relayPanel.view",
                    "name": "Relay"
                }
            ]
        },
        "configuration": {
            "title": "Relay Panel",
            "properties": {
                "relayPanel.port": {
                    "type": "number",
                    "default": 23517
                },
                "relayPanel.host": {
                    "type": "string",
                    "default": "127.0.0.1",
                    "description": "Bind address. Use 0.0.0.0 to accept from Docker/Lando containers on Linux."
                },
                "relayPanel.maxItems": {
                    "type": "number",
                    "default": 500
                },
                "relayPanel.colorStyle": {
                    "type": "string",
                    "enum": ["tint-origin", "border", "tint", "dot", "origin"],
                    "enumDescriptions": [
                        "A full-row tint plus a labeled color chip and tinted origin in the footer.",
                        "A 3px colored bar on the left edge of the entry.",
                        "A soft full-row background tint plus a left border.",
                        "A filled color dot in the left gutter (matches the filter dots).",
                        "A color chip and tinted origin in the footer only."
                    ],
                    "default": "tint-origin",
                    "description": "How a payload's ray()->color() is visually applied to its entry. Switch it from the panel's Color Style… title-bar action."
                },
                "relayPanel.resolveOriginsFromWorkspace": {
                    "type": "boolean",
                    "default": true,
                    "description": "When an origin path isn't found on disk as-is, locate the file by its tail under the window's workspace folders (zero-config click-to-jump for container paths). Disable to require explicit relayPanel.pathMappings."
                },
                "relayPanel.pathMappings": {
                    "type": "array",
                    "default": [],
                    "description": "Explicit override for click-to-jump (highest precedence). Each entry rewrites a remote path prefix to a local one, e.g. { \"remote\": \"/app\", \"local\": \"/Users/you/project\" }. Use to disambiguate when the same relative path exists in multiple open folders.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "remote": { "type": "string" },
                            "local": { "type": "string" }
                        },
                        "required": ["remote", "local"]
                    }
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.120.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "typescript-eslint": "^8.56.1",
        "eslint": "^9.39.3",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2"
    }
}
