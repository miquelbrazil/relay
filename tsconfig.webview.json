{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"strict": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": []
	},
	"include": [
		"media/src/**/*.ts",
		"src/protocol.ts"
	]
}
